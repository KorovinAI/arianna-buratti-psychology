---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Privacy Policy — Arianna Buratti, Psychologist"
  description="Privacy policy for Arianna Buratti Psychology. How we collect, use, and protect your personal information."
  activeNav={null}
>

  <Hero
    title="Privacy Policy"
    image="/images/room-6.webp"
  />

  <section class="section">
    <div class="container content-section" style="max-width: 800px;">

      <p class="text-muted">Last updated: March 2026</p>

      <h2>Overview</h2>
      <hr class="divider" />
      <p>Arianna Buratti Psychology is committed to protecting your privacy and handling your personal information responsibly. This policy explains how I collect, use, store, and disclose your personal information in accordance with the Australian Privacy Act 1988 and the Australian Privacy Principles (APPs).</p>

      <h2>Information I Collect</h2>
      <hr class="divider" />
      <p>I may collect the following types of personal information:</p>
      <ul>
        <li>Name, contact details (phone, email, address)</li>
        <li>Date of birth and Medicare details</li>
        <li>Referral information from your GP or other health professionals</li>
        <li>Health information relevant to your psychological care</li>
        <li>Session notes and treatment plans</li>
        <li>Information you provide via the website contact form</li>
      </ul>

      <h2>How I Use Your Information</h2>
      <hr class="divider" />
      <p>Your personal information is used to:</p>
      <ul>
        <li>Provide psychological assessment and treatment</li>
        <li>Communicate with you about appointments and care</li>
        <li>Process Medicare claims and invoicing</li>
        <li>Comply with legal and regulatory obligations</li>
        <li>Respond to enquiries submitted via the website</li>
      </ul>

      <h2>Disclosure</h2>
      <hr class="divider" />
      <p>I will not disclose your personal or health information to third parties without your consent, except where:</p>
      <ul>
        <li>Required or authorised by law (e.g., mandatory reporting obligations)</li>
        <li>Necessary to prevent a serious threat to life, health, or safety</li>
        <li>You have provided written consent for disclosure to a specific party (e.g., your GP)</li>
      </ul>

      <h2>Storage &amp; Security</h2>
      <hr class="divider" />
      <p>Your records are stored securely in accordance with AHPRA and APS guidelines. Electronic records are protected by encryption and access controls. Paper records, where applicable, are stored in locked facilities.</p>
      <p>Client records are retained for a minimum of seven years after the last session, or until a minor client turns 25, in accordance with Australian legal requirements.</p>

      <h2>Your Rights</h2>
      <hr class="divider" />
      <p>You have the right to:</p>
      <ul>
        <li>Access the personal information I hold about you</li>
        <li>Request corrections to inaccurate information</li>
        <li>Make a complaint about how your information has been handled</li>
      </ul>
      <p>To make a request or complaint, please contact me at <a href="mailto:info@ab-psych.com.au">info@ab-psych.com.au</a> or call <a href="tel:0490786047">0490 786 047</a>.</p>

      <h2>Website</h2>
      <hr class="divider" />
      <p>This website does not use cookies or third-party tracking. The contact form sends your message directly via Netlify Forms. Your submission data is not stored on this website.</p>

      <h2>Changes to This Policy</h2>
      <hr class="divider" />
      <p>This policy may be updated from time to time. Any changes will be reflected on this page with an updated revision date.</p>

    </div>
  </section>

</BaseLayout>
