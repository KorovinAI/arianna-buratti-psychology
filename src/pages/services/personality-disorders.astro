---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FooterCta from '../../components/FooterCta.astro';
export const prerender = true;
---

<BaseLayout
  title="Personality Disorders — Arianna Buratti, Psychologist"
  description="Personality disorder support, counselling, and screening with Arianna Buratti in Carlton, Melbourne. Schema Therapy and DBT-informed care for personality challenges."
  activeNav="services"
>

  <Hero
    title="Personality Disorders"
    subtitle="Compassionate support, counselling, and screening assessments."
    image="/images/service-personality.jpg"
  />

  <section class="section">
    <div class="container content-section" style="max-width: 800px;">
      <h2>Understanding Personality Disorders</h2>
      <hr class="divider" />
      <p>Personality disorders involve long-standing patterns of thinking, feeling, and behaving that can cause significant distress and difficulty in relationships, work, and daily life. These patterns often develop early and can feel deeply ingrained — but with the right support, meaningful change is possible.</p>
      <p>I provide support and counselling for individuals experiencing challenges related to:</p>
      <ul>
        <li>Borderline personality disorder (BPD) / Emotionally unstable personality</li>
        <li>Avoidant personality traits</li>
        <li>Narcissistic personality features</li>
        <li>Dependent personality patterns</li>
        <li>Antisocial and conduct-related difficulties</li>
        <li>Mixed or unspecified personality difficulties</li>
        <li>Emotional instability and intense mood shifts</li>
        <li>Chronic feelings of emptiness or identity confusion</li>
      </ul>
    </div>
  </section>

  <section class="section section--warm">
    <div class="container content-section" style="max-width: 800px;">
      <h2>Screening &amp; Counselling</h2>
      <hr class="divider" />
      <p>I offer screening assessments to help identify personality disorder-related patterns. These are not full diagnostic evaluations but can provide clarity on whether further assessment or specific treatment approaches would be beneficial.</p>
      <p>For ongoing support, I primarily use <a href="/approaches/">Schema Therapy and DBT</a> — two of the most effective evidence-based approaches for personality disorders. Schema Therapy helps identify and change deep-rooted patterns (schemas) that drive unhelpful behaviours, while DBT builds skills in emotional regulation, distress tolerance, mindfulness, and interpersonal effectiveness.</p>
      <p>Therapy for personality-related concerns is often longer-term, and I'm committed to working with you at a pace that feels safe and sustainable.</p>
      <p>Sessions are available in person or via <a href="/telehealth/">telehealth</a>.</p>
    </div>
  </section>

  <FooterCta title="Ready to Start?" body="Reach out to book your first session or ask any questions." />

</BaseLayout>
