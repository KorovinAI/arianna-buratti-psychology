---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  activeNav?: 'home' | 'about' | 'services' | 'approaches' | 'fees' | 'contact' | null;
  includeSchemaOrg?: boolean;
}

const {
  title,
  description,
  activeNav = null,
  includeSchemaOrg = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const navLinks = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/about/', label: 'About', key: 'about' },
  { href: '/services/', label: 'Services', key: 'services', dropdown: [
    { href: '/services/individual-therapy/', label: 'Individual Therapy' },
    { href: '/services/relationship-work/', label: 'Relationship Work' },
    { href: '/services/adhd/', label: 'ADHD' },
    { href: '/services/anxiety-depression/', label: 'Anxiety & Depression' },
    { href: '/services/personality-disorders/', label: 'Personality Disorders' },
    { href: '/telehealth/', label: 'Telehealth' },
  ]},
  { href: '/approaches/', label: 'Approaches', key: 'approaches' },
  { href: '/fees/', label: 'Fees', key: 'fees' },
  { href: '/contact/', label: 'Contact', key: 'contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/brand-assets/AB-favicon-32px.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/images/brand-assets/android-chrome-192x192.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="/images/brand-assets/android-chrome-512x512.png" />
  <link rel="apple-touch-icon" href="/images/brand-assets/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />

  {includeSchemaOrg && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Psychologist",
      "name": "Arianna Buratti",
      "description": "Registered psychologist providing evidence-based therapy in Carlton, Melbourne. Specialising in anxiety, depression, ADHD, trauma, and relationship counselling.",
      "url": "https://ab-psych.com.au",
      "telephone": "+61490786047",
      "email": "info@ab-psych.com.au",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "165–167 Drummond Street",
        "addressLocality": "Carlton",
        "addressRegion": "VIC",
        "postalCode": "3053",
        "addressCountry": "AU"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
        "opens": "09:00",
        "closes": "20:00"
      },
      "priceRange": "$220 per session",
      "knowsLanguage": ["English", "Italian"],
      "memberOf": {
        "@type": "Organization",
        "name": "Australian Psychological Society"
      }
    })} />
  )}
</head>
<body>

  <!-- Top Contact Bar -->
  <div class="top-bar">
    <div class="container top-bar__inner">
      <span class="top-bar__address">165–167 Drummond Street, Carlton VIC 3053</span>
      <div class="top-bar__right">
        <a href="tel:0490786047">
          <svg class="top-bar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="top-bar__label">0490 786 047</span>
        </a>
        <a href="mailto:info@ab-psych.com.au">
          <svg class="top-bar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span class="top-bar__label">info@ab-psych.com.au</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Header -->
  <header class="header" id="header">
    <div class="header__inner">
      <a href="/" class="header__logo">
        <img src="/images/brand-assets/AB-logo-horizontal-600px.png" srcset="/images/brand-assets/AB-logo-horizontal-300px.png 1x, /images/brand-assets/AB-logo-horizontal-600px.png 2x, /images/brand-assets/AB-logo-horizontal-1200px.png 3x" alt="Arianna Buratti — Psychologist" width="600" height="300" />
      </a>
      <nav class="nav">
        <ul class="nav__list" id="navList">
          {navLinks.map((link) => (
            link.dropdown ? (
              <li class="nav__item--dropdown">
                <a href={link.href} class={`nav__link${activeNav === link.key ? ' nav__link--active' : ''}`}>{link.label}</a>
                <div class="nav__dropdown">
                  {link.dropdown.map((d) => (
                    <a href={d.href}>{d.label}</a>
                  ))}
                </div>
              </li>
            ) : (
              <li>
                <a href={link.href} class={`nav__link${activeNav === link.key ? ' nav__link--active' : ''}`}>{link.label}</a>
              </li>
            )
          ))}
        </ul>
        <a href="/contact/" class="btn btn--primary nav__cta">Get in Touch</a>
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </nav>
    </div>
  </header>
  <div class="nav-overlay" id="navOverlay"></div>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer__grid">
      <div class="footer__brand">
        <img src="/images/brand-assets/AB-logo-horizontal-600px.png" srcset="/images/brand-assets/AB-logo-horizontal-300px.png 1x, /images/brand-assets/AB-logo-horizontal-600px.png 2x, /images/brand-assets/AB-logo-horizontal-1200px.png 3x" alt="Arianna Buratti — Psychologist" width="600" height="300" />
        <p>Compassionate, evidence-based psychological care to help individuals navigate life's challenges and achieve lasting wellbeing.</p>
        <p class="footer__linkedin">
          <a href="https://www.linkedin.com/in/ariannaburatti/" target="_blank" rel="noopener">LinkedIn</a>
        </p>
      </div>
      <div class="footer__links">
        <h4>Quick Links</h4>
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/services/">Services</a>
        <a href="/approaches/">Approaches</a>
        <a href="/fees/">Fees &amp; Rebates</a>
        <a href="/contact/">Contact</a>
        <a href="/privacy/">Privacy Policy</a>
      </div>
      <div class="footer__contact">
        <h4>Contact</h4>
        <p>165–167 Drummond Street<br />Carlton VIC 3053</p>
        <p><a href="tel:0490786047">0490 786 047</a></p>
        <p><a href="mailto:info@ab-psych.com.au">info@ab-psych.com.au</a></p>
        <p class="footer__hours">Mon–Sat: 9am – 8pm</p>
        <p class="footer__registration">AHPRA Registered &bull; MAPS</p>
      </div>
    </div>
    <div class="footer__bottom">
      <div class="container">
        <span>&copy; Arianna Buratti. All rights reserved.</span>
        <span><a href="/privacy/" class="footer__privacy-link">Privacy Policy</a></span>
      </div>
    </div>
  </footer>

  <!-- Sticky Mobile CTA -->
  <div class="sticky-cta">
    <a href="/contact/" class="btn btn--primary">Get in Touch</a>
  </div>

  <script src="/scripts/nav.js" is:inline></script>
</body>
</html>
